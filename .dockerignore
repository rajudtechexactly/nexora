# Keep the Docker build context small and free of secrets/large artifacts.
.git
.gitignore
.github

# Local env / secrets — set these as Render environment variables instead.
.env
.env.*
*.jks
*.keystore

# NativePHP mobile build output + Android toolchain (huge, irrelevant to API)
nativephp/
*.apk
*.aab
android-sdk/
android-tools/

# Dependencies / build caches (reinstalled inside the image)
vendor/
node_modules/
public/build/
public/hot

# Runtime / local state
storage/app/native-build/
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
database/*.sqlite

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Docs / prompts not needed at runtime
prompt.md
*.log
